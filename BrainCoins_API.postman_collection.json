    {
      "name": "🎁 Vantagens",
      "item": [
        {
          "name": "Listar vantagens ativas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vantagens",
              "host": ["{{base_url}}"],
              "path": ["vantagens"]
            },
            "description": "Retorna apenas as vantagens ativas (ativo=true) e com estoque. Usado pela tela de alunos."
          }
        },
        {
          "name": "Listar todas as vantagens (inclusive inativas)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vantagens/todas",
              "host": ["{{base_url}}"],
              "path": ["vantagens", "todas"]
            },
            "description": "Retorna todas as vantagens independente de status. Usado por administradores."
          }
        },
        {
          "name": "Buscar vantagem por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vantagens/{{vantagemId}}",
              "host": ["{{base_url}}"],
              "path": ["vantagens", "{{vantagemId}}"]
            },
            "description": "Retorna os detalhes de uma vantagem específica."
          }
        },
        {
          "name": "Listar vantagens de uma empresa",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vantagens/empresa/{{empresaId}}",
              "host": ["{{base_url}}"],
              "path": ["vantagens", "empresa", "{{empresaId}}"]
            },
            "description": "Retorna todas as vantagens cadastradas por uma empresa específica (ativas e inativas)."
          }
        },
        {
          "name": "Criar vantagem (JSON)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empresaId\": {{empresaId}},\n  \"nome\": \"Desconto de 30% no Restaurante\",\n  \"descricao\": \"Apresente o cupom para obter 30% de desconto em qualquer item do cardápio.\",\n  \"foto\": null,\n  \"custo\": 150,\n  \"estoque\": 20\n}"
            },
            "url": {
              "raw": "{{base_url}}/vantagens",
              "host": ["{{base_url}}"],
              "path": ["vantagens"]
            },
            "description": "Cria uma nova vantagem sem foto. Para cadastrar com foto de arquivo, use o fluxo: 1) POST /uploads → obter URL, 2) informar a URL no campo `foto`. Retorna 201 Created."
          }
        },
        {
          "name": "Atualizar vantagem",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empresaId\": {{empresaId}},\n  \"nome\": \"Desconto de 40% no Restaurante\",\n  \"descricao\": \"Apresente o cupom para obter 40% de desconto em qualquer item do cardápio.\",\n  \"foto\": null,\n  \"custo\": 200,\n  \"estoque\": 15\n}"
            },
            "url": {
              "raw": "{{base_url}}/vantagens/{{vantagemId}}",
              "host": ["{{base_url}}"],
              "path": ["vantagens", "{{vantagemId}}"]
            },
            "description": "Atualiza os dados de uma vantagem existente."
          }
        },
        {
          "name": "Deletar vantagem",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vantagens/{{vantagemId}}",
              "host": ["{{base_url}}"],
              "path": ["vantagens", "{{vantagemId}}"]
            },
            "description": "Remove uma vantagem do catálogo. Retorna 204 No Content."
          }
        },
        {
          "name": "Ativar / Desativar vantagem (toggle)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vantagens/{{vantagemId}}/toggle",
              "host": ["{{base_url}}"],
              "path": ["vantagens", "{{vantagemId}}", "toggle"]
            },
            "description": "Alterna o campo `ativo` da vantagem (true → false ou false → true). Vantagens inativas não aparecem no catálogo do aluno."
          }
        }
      ]
    },
    {
      "name": "🎫 Resgates",
      "item": [
        {
          "name": "Resgatar vantagem (Aluno)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alunoId\": {{alunoId}},\n  \"vantagemId\": {{vantagemId}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/vantagens/resgatar",
              "host": ["{{base_url}}"],
              "path": ["vantagens", "resgatar"]
            },
            "description": "Aluno resgata uma vantagem usando suas moedas.\n\nRegras de negócio:\n- Saldo do aluno é debitado atomicamente\n- Estoque da vantagem é decrementado\n- Cupom único é gerado (8 caracteres alfanuméricos)\n- E-mail é enviado ao aluno e à empresa (async)\n- Resgate expira automaticamente após 15 dias\n\nErros possíveis:\n- 400 SALDO_INSUFICIENTE\n- 400 ESTOQUE_ESGOTADO\n- 404 Aluno/Vantagem não encontrado\n\nRetorna 201 Created com dados do resgate (cupom, expiraEm, etc.)."
          }
        },
        {
          "name": "Listar resgates de um aluno",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/resgates/aluno/{{alunoId}}",
              "host": ["{{base_url}}"],
              "path": ["resgates", "aluno", "{{alunoId}}"]
            },
            "description": "Retorna todos os resgates de um aluno, ordenados do mais recente para o mais antigo.\n\nStatus possíveis: `ativo`, `expirado`, `retirado`."
          }
        },
        {
          "name": "Listar resgates de uma empresa",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/resgates/empresa/{{empresaId}}",
              "host": ["{{base_url}}"],
              "path": ["resgates", "empresa", "{{empresaId}}"]
            },
            "description": "Retorna todos os resgates de vantagens pertencentes à empresa, ordenados do mais recente. Inclui nome do aluno e cupom para validação na retirada."
          }
        },
        {
          "name": "Confirmar retirada (Empresa)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/resgates/{{resgateId}}/confirmar",
              "host": ["{{base_url}}"],
              "path": ["resgates", "{{resgateId}}", "confirmar"]
            },
            "description": "Empresa confirma que o aluno retirou o benefício. Status do resgate muda de `ativo` → `retirado`.\n\nErro: 400 se o resgate não estiver com status `ativo`."
          }
        }
      ]
    },
    {
      "name": "💳 Transações",
      "item": [
        {
          "name": "Enviar moedas (Professor → Aluno)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"professorId\": {{professorId}},\n  \"alunoId\": {{alunoId}},\n  \"valor\": {{transacaoValor}},\n  \"motivo\": \"Excelente desempenho na atividade de pesquisa\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transacoes",
              "host": ["{{base_url}}"],
              "path": ["transacoes"]
            },
            "description": "Professor envia moedas a um aluno como reconhecimento.\n\nRegras de negócio:\n- Operação atômica (@Transactional)\n- Saldo do professor é debitado\n- Saldo do aluno é creditado\n- E-mail de notificação é enviado ao aluno (async)\n\nErros: 400 SALDO_INSUFICIENTE, 404 Professor/Aluno não encontrado.\n\nRetorna 201 Created."
          }
        },
        {
          "name": "Listar todas as transações de um aluno",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transacoes/aluno/{{alunoId}}",
              "host": ["{{base_url}}"],
              "path": ["transacoes", "aluno", "{{alunoId}}"]
            },
            "description": "Retorna o histórico completo de transações de um aluno (enviadas e recebidas)."
          }
        },
        {
          "name": "Listar transações recebidas pelo aluno",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transacoes/aluno/{{alunoId}}/recebidas",
              "host": ["{{base_url}}"],
              "path": ["transacoes", "aluno", "{{alunoId}}", "recebidas"]
            },
            "description": "Retorna apenas as transações em que o aluno foi o destinatário (recebeu moedas de professores)."
          }
        },
        {
          "name": "Listar transações enviadas pelo professor",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transacoes/professor/{{professorId}}",
              "host": ["{{base_url}}"],
              "path": ["transacoes", "professor", "{{professorId}}"]
            },
            "description": "Retorna o extrato de todas as distribuições realizadas por um professor."
          }
        }
      ]
    },
    {
