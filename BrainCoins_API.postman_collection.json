  },
  "item": [
    {
      "name": "👨‍🎓 Alunos",
      "item": [
        {
          "name": "Listar todos os alunos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/alunos",
              "host": ["{{base_url}}"],
              "path": ["alunos"]
            },
            "description": "✅ Retorna a lista de todos os alunos cadastrados"
          }
        },
        {
          "name": "Buscar aluno por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/alunos/10",
              "host": ["{{base_url}}"],
              "path": ["alunos", "10"]
            },
            "description": "✅ Retorna os dados de um aluno específico (ex: ID 10)"
          }
        },
        {
          "name": "Criar novo aluno",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria Silva\",\n  \"cpf\": \"12345678901\",\n  \"rg\": \"1234567\",\n  \"endereco\": \"Rua das Flores, 123\",\n  \"instituicaoId\": 1,\n  \"curso\": \"Engenharia de Software\",\n  \"email\": \"maria.silva@university.edu\",\n  \"senha\": \"SenhaAluno123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/alunos",
              "host": ["{{base_url}}"],
              "path": ["alunos"]
            },
            "description": "✅ Cria um novo aluno no sistema (requer instituicaoId válido)"
          }
        },
        {
          "name": "Atualizar aluno",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria Silva Santos\",\n  \"cpf\": \"12345678901\",\n  \"rg\": \"1234567\",\n  \"endereco\": \"Rua das Flores, 200\",\n  \"instituicaoId\": 1,\n  \"curso\": \"Engenharia de Software\",\n  \"email\": \"maria.silva@university.edu\",\n  \"senha\": \"NovaSenhaAluno456!\"\n}"
            },
            "url": {
