          "name": "Fazer upload de imagem",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "arquivo",
                  "type": "file",
                  "description": "Arquivo de imagem (JPG, PNG, GIF, WEBP). Tamanho máximo: 5MB."
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/uploads",
              "host": ["{{base_url}}"],
              "path": ["uploads"]
            },
            "description": "Faz upload de um arquivo de imagem e retorna a URL pública relativa ao servidor.\n\nResposta: { \"url\": \"/uploads/uuid.jpg\" }\n\nA imagem fica acessível em: {{base_url}}/uploads/uuid.jpg\n\nUso típico: upload da foto de uma Vantagem antes de criá-la (POST /vantagens)."
          }
        }
      ]
    },
    {
      "name": "⚙️ Admin (Desenvolvimento & Testes)",
      "item": [
        {
          "name": "Adicionar saldo ao Professor",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/professor/{{professorId}}/saldo/{{adminValor}}",
