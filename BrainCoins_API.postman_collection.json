{
  "info": {
    "name": "BrainCoins API",
    "description": "API BrainCoins - Sistema de Moeda Estudantil\n\nBase URL: {{base_url}} (padrão: http://localhost:8080)\n\nEntidades: Alunos, Professores, Empresas, Instituições, Transações, Vantagens, Resgates.\n\nFluxo básico:\n1. Criar Instituição → importar Professores via CSV\n2. Criar Aluno e Empresa\n3. Fazer login (obtém dados do usuário)\n4. Professor distribui moedas → Aluno resgata vantagem da Empresa",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Autenticação",
      "item": [
        {
          "name": "Login - Aluno",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao.silva@aluno.edu\",\n  \"senha\": \"SenhaAluno123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login/aluno",
              "host": ["{{base_url}}"],
              "path": ["login", "aluno"]
            },
            "description": "Autentica um aluno. Retorna os dados completos (id, nome, saldo, curso, etc.)."
          }
        },
        {
          "name": "Login - Empresa",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"contato@empresa.com\",\n  \"senha\": \"SenhaEmpresa123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login/empresa",
              "host": ["{{base_url}}"],
              "path": ["login", "empresa"]
            },
            "description": "Autentica uma empresa parceira. Retorna os dados completos (id, nome, cnpj, etc.)."
          }
        },
        {
          "name": "Login - Professor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"professor@universidade.edu\",\n  \"senha\": \"SenhaProf123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login/professor",
              "host": ["{{base_url}}"],
              "path": ["login", "professor"]
            },
            "description": "Autentica um professor. Retorna os dados completos (id, nome, saldo, instituicaoNome, etc.)."
          }
        },
        {
          "name": "Login - Instituição",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"contato@ufmg.br\",\n  \"senha\": \"SenhaInst123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login/instituicao",
              "host": ["{{base_url}}"],
              "path": ["login", "instituicao"]
            },
            "description": "Autentica uma instituição de ensino. Retorna os dados completos (id, nome, cnpj, etc.)."
          }
        }
      ]
    },
    {
      "name": "👨‍🎓 Alunos",
      "item": [
        {
          "name": "Listar todos os alunos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/alunos",
              "host": ["{{base_url}}"],
              "path": ["alunos"]
            },
            "description": "Retorna a lista de todos os alunos cadastrados."
          }
        },
        {
          "name": "Buscar aluno por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/alunos/{{alunoId}}",
              "host": ["{{base_url}}"],
              "path": ["alunos", "{{alunoId}}"]
            },
            "description": "Retorna os dados completos de um aluno, incluindo saldo de moedas."
          }
        },
        {
          "name": "Criar novo aluno",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João da Silva\",\n  \"cpf\": \"123.456.789-01\",\n  \"rg\": \"1234567\",\n  \"endereco\": \"Rua das Flores, 123, Belo Horizonte - MG\",\n  \"instituicao\": \"UFMG\",\n  \"curso\": \"Engenharia de Software\",\n  \"email\": \"joao.silva@aluno.edu\",\n  \"senha\": \"SenhaAluno123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/alunos",
              "host": ["{{base_url}}"],
              "path": ["alunos"]
            },
            "description": "Cria um novo aluno. O campo `instituicao` é o nome (String) da instituição. Saldo inicial = 0. Retorna 201 Created."
          }
        },
        {
          "name": "Atualizar aluno",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João da Silva Santos\",\n  \"cpf\": \"123.456.789-01\",\n  \"rg\": \"1234567\",\n  \"endereco\": \"Rua das Flores, 200, Belo Horizonte - MG\",\n  \"instituicao\": \"UFMG\",\n  \"curso\": \"Ciência da Computação\",\n  \"email\": \"joao.silva@aluno.edu\",\n  \"senha\": \"NovaSenha456!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/alunos/{{alunoId}}",
              "host": ["{{base_url}}"],
              "path": ["alunos", "{{alunoId}}"]
            },
            "description": "Atualiza os dados cadastrais de um aluno. O saldo de moedas não é alterado por este endpoint."
          }
        },
        {
          "name": "Deletar aluno",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/alunos/{{alunoId}}",
              "host": ["{{base_url}}"],
              "path": ["alunos", "{{alunoId}}"]
            },
            "description": "Remove um aluno do sistema. Retorna 204 No Content."
          }
        }
      ]
    },
