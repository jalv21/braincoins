          }
        },
        {
          "name": "Deletar aluno",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/alunos/10",
              "host": ["{{base_url}}"],
              "path": ["alunos", "10"]
            },
            "description": "✅ Deleta um aluno do sistema"
          }
        }
      ]
