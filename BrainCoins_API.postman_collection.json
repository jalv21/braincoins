        {
          "name": "Importar professores via CSV",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "arquivo",
                  "type": "file",
                  "description": "Arquivo CSV com cabeçalho: nome,cpf,departamento,curso"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/instituicoes/{{instituicaoId}}/importar-professores",
