    {
      "name": "💳 Transações",
      "item": [
        {
          "name": "Criar transação (Professor → Aluno)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"professorId\": 1,\n  \"alunoId\": 10,\n  \"valor\": 250,\n  \"motivo\": \"Desempenho excepcional na atividade de pesquisa\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transacoes",
              "host": ["{{base_url}}"],
              "path": ["transacoes"]
            },
            "description": "✅ Cria uma transação atômica de moedas do professor para o aluno | Returns 201 Created"
          }
        },
        {
          "name": "Listar todas as transações de um aluno",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transacoes/aluno/10",
              "host": ["{{base_url}}"],
              "path": ["transacoes", "aluno", "10"]
            },
            "description": "✅ Retorna todas as transações de um aluno (enviadas e recebidas)"
          }
        },
        {
          "name": "Listar transações recebidas pelo aluno",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transacoes/aluno/10/recebidas",
              "host": ["{{base_url}}"],
              "path": ["transacoes", "aluno", "10", "recebidas"]
            },
            "description": "✅ Retorna apenas as transações recebidas pelo aluno (envios de professores)"
          }
        },
        {
          "name": "Listar transações enviadas pelo professor",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transacoes/professor/1",
              "host": ["{{base_url}}"],
              "path": ["transacoes", "professor", "1"]
            },
            "description": "✅ Retorna todas as transações enviadas por um professor"
          }
        }
      ]
    },
